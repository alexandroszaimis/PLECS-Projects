"eF9iMiA9IHhfYjE7IHhfYjEgPSB4X2I7CiAgICB5X2IyID0geV9iMTsgeV9iMSA9IHlfYjsKCiAgI"
"CAvLyBGbHV4IGVzdGltYXRlcwogICAgcHNpX2EgPSB5X2E7CiAgICBwc2lfYiA9IHlfYjsKCk91dH"
"B1dCgwKSA9IHBzaV9hOwpPdXRwdXQoMSkgPSBwc2lfYjsKT3V0cHV0KDIpID0gVHM7"
        Show          off
      }
      Parameter {
        Variable      "UpdateFcn"
        Value         "\n"
"    // Desired analog cutoff\n"
"    double wc = 2.0 * PI * fhp;                 // rad/s\n"
"\n"
"    // Bilinear pre-warp\n"
"    double Wc  = (2.0 / Ts) * tan(0.5 * wc * Ts);\n"
"\n"
"    // Convenience terms\n"
"    double TsW  = Ts * Wc;\n"
"    double TsW2 = TsW * Wc;                      // = Ts^2 * Wc^2\n"
"\n"
"    // Denominator (normalized by d0 later)\n"
"    double d0 = 4.0 + 2.0f*SQRT2*TsW + TsW2;\n"
"    double d1 = 2.0*TsW2 - 8.0f;\n"
"    double d2 = 4.0 - 2.0f*SQRT2*TsW + TsW2;\n"
"\n"
"    // Numerator for H(s) = s / (s^2 + sqrt(2) wc s + wc^2)\n"
"    double n0 = 2.0 * Ts;\n"
"    double n1 = 0.0;\n"
"    double n2 = -2.0 * Ts;\n"
"\n"
"    // Normalize\n"
"    double inv_d0 = 1.0 / d0;\n"
"    b0 = n0 * inv_d0;\n"
"    b1 = n1 * inv_d0;   // 0\n"
"    b2 = n2 * inv_d0;\n"
"    a1 = d1 * inv_d0;   // NOTE: used with minus in the diff eq\n"
"    a2 = d2 * inv_d0;"
        Show          off
      }
      Parameter {
        Variable      "DerivativeFcn"
        Value         ""
        Show          off
      }
