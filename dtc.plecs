            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "Parameters"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "LangStandard"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "GnuExtensions"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "HighlightLevel"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "#define SWITCH_PERIOD 100e-6\n"
"\n"
"int in[3];\n"
"int in_prv[3];\n"
"\n"
"int out[3];\n"
"int out_prv[3];\n"
"\n"
"int sw_flag[3];\n"
"\n"
"float curr_time;\n"
"\n"
"float delta_t[3];\n"
"float prv_time[3];\n"
"float last_delta_t[3];"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "for(int i=0; i<3; i++){\n"
"\tprv_time[i] = 0;\n"
"\tout_prv[i] = 0;\n"
"}"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "curr_time = CurrentTime;\n"
"\n"
"for(int i=0; i<3; i++){\n"
"\n"
"\tin[i] = InputSignal(0,i);\n"
"\n"
"\tdelta_t[i] = curr_time - prv_time[i];\n"
"\n"
"\tsw_flag[i] = 0;\n"
"\n"
"\tif((delta_t[i]+last_delta_t[i]) > SWITCH_PERIOD){\n"
"\t\tsw_flag[i] = 1;\n"
"\t}\n"
"\n"
"\tif(in[i] != out_prv[i]){\n"
"\t\tif(sw_flag[i]){\n"
"\t\t\tout[i] = in[i];\n"
"\t\t\tprv_time[i] = curr_time;\n"
"\t\t\tlast_delta_t[i] = delta_t[i];\n"
"\t\t}\n"
"\t\telse{\n"
"\t\t\tout[i] = out_prv[i];\n"
"\t\t}\n"
"\t}\n"
"\telse{\n"
"\t\tout[i] = out_prv[i];\n"
"\t}\n"
"\n"
"\tout_prv[i] = out[i];\n"
"\n"
"\tOutputSignal(0,i) = out[i];\n"
"}"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "StoreCustomStateFcn"
            Value         "for(int i=0; i<3; i++){\n"
"\tWriteCustomStateDouble(prv_time[i]);\n"
"\tWriteCustomStateDouble(last_delta_t[i]);\n"
"\n"
"\tWriteCustomStateInt(out_prv[i]);\n"
"\n"
"\tWriteCustomStateInt(in_prv[i]);\n"
"}"
            Show          off
          }
          Parameter {
            Variable      "RestoreCustomStateFcn"
            Value         ""
            Show          off
          }
        }
