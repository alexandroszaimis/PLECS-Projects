                Value         "float LastTime;\n"
"float ts;\n"
"float w_prv;"
                Show          off
              }
              Parameter {
                Variable      "StartFcn"
                Value         "\n"
                Show          off
              }
              Parameter {
                Variable      "OutputFcn"
                Value         "ts = CurrentTime - LastTime;\n"
"LastTime = CurrentTime;\n"
"\n"
"float w = Input(0);\n"
"float max_dwdt = Input(1);\n"
"\n"
"float dwdt = (w-w_prv)/ts;\n"
"\n"
"if(dwdt > max_dwdt)\n"
"{\n"
"\tw = w_prv + ts*max_dwdt;\n"
"}\n"
"\n"
"if(dwdt < -max_dwdt)\n"
"{\n"
"\tw = w_prv - ts*max_dwdt;\n"
"}\n"
"\n"
"w_prv = w;\n"
"\n"
"Output(0) = w;"
                Show          off
              }
