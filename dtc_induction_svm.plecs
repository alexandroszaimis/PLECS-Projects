  Name          "dtc_induction_svm"
  Version       "4.9"
  CircuitModel  "ContStateSpace"
  StartTime     "0.0"
  TimeSpan      "2"
  Timeout       ""
  Solver        "auto"
  MaxStep       "1e-3"
  InitStep      "-1"
  FixedStep     "1e-3"
  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-3"
  AbsTol        "-1"
  TurnOnThreshold "0"
  NonIdealSwitchResistance "1"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "3"
  NegativeSwitchLossMsg "3"
  DivisionByZeroMsg "3"
  DatatypeOverflowMsg "3"
  DatatypeInheritanceConflictMsg "2"
  ContSampleTimeConflictMsg "2"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "0"
  AlgebraicLoopWithStateMachineMsg "3"
  AssertionAction "1"
  FixedPointDatatypeOverride "1"
  InitializationCommands "v_base = 400;\nw_base = 2*pi*50;\n\nLsig = 0.0416\nR"
"R = 2.106\nRs = 4.3\npsi_nom = 0.9072\n%psi_nom = 0.72\nLls = (Lsig/2);%/(2*p"
"i*60);\nLlr = (Lsig/2);\nLm = 0.3365;%/(2*pi*60);\n\nId_nom = psi_nom/Lm\nJ ="
" 0.01\nnp = 2\n\nsample_time = 25e-6\nsw_freq = 20e3\ncontrol_sample_time = s"
"ample_time\n\nVdc = 400\n\nKp_trq = 100;\nKi_trq = 5000;\nKp_flux = 2000;\nKi"
"_flux = 1000;\n\n%Kp_trq = 500;\n%Ki_trq = 1e4;\n%Kp_flux = 2e3;\n%Ki_flux = "
"1e4;\nKaw_flux = 1;\nKaw_trq = 1;\n\nimax = 10;\nmax_trq = 15;\n\nmax_dwdt = "
"max_trq/J;\n\nfc = 40;\naw = 2*pi*fc;\n\nLam = 0;\n\nt_rise_s = 200e-3;\nb = "
"0;\n\nas = log(9)/t_rise_s;\nKps = as*J/np;\nKis = as^2*J/np;\nba = (as*J-b)/"
"np;\n\nspeed_sample_time = 100e-6;\n\nMA1 = 2/sqrt(3);\n\nnom_rpm = 1500*Vdc/"
"v_base;\nw_base = nom_rpm * 2*pi/60;\n\nlamda_svcm = 1.5;\ntr_svcm = 20e-3;\n"
"al_svcm = log(9)/tr_svcm;\nwdelta = 0.1*w_base;"
