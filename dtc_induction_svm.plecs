          }
          Parameter {
            Variable      "Parameters"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "LangStandard"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "GnuExtensions"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "HighlightLevel"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "float psi_ramp;\n"
"float pr_time;\n"
"float nonsat;\n"
"\n"
"double max(double num1, double num2){\n"
"\tif(num1 >= num2)\n"
"\t\treturn num1;\n"
"\telse\n"
"\t\treturn num2;\n"
"}\n"
"double min(double num1, double num2){\n"
"\tif(num1 <= num2)\n"
"\t\treturn num1;\n"
"\telse\n"
"\t\treturn num2;\n"
"}"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "#include <math.h>\n"
"\n"
"psi_ramp = 0;\n"
"pr_time = 0;"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "float input = InputSignal(0,0);\n"
"float maxval = InputSignal(0,1);\n"
"float minval = InputSignal(0,2);\n"
"\n"
"float ts = CurrentTime - pr_time;\n"
"\n"
"pr_time = CurrentTime;\n"
"\n"
"if(nonsat > maxval)\n"
"{\n"
"\tnonsat = maxval;\n"
"}\n"
"if(nonsat < minval)\n"
"{\n"
"\tnonsat = minval;\n"
"}\n"
"\n"
"nonsat = nonsat + input * ts;\n"
"\n"
"float sat = min(max(nonsat, minval), maxval);\n"
"\n"
"OutputSignal(0, 0) = sat;"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "StoreCustomStateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "RestoreCustomStateFcn"
            Value         ""
            Show          off
          }
