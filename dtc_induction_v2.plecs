            Value         "double vector = InputSignal(0,0);\n"
"\n"
"double angle;\n"
"\n"
"if(vector != 0 && vector != 7)\n"
"{\n"
"\tangle = vector*3.14159/3;\n"
"\tprv_angle = angle;\n"
"}\n"
"else\n"
"{\n"
"\tangle = prv_angle;\n"
"}\n"
"OutputSignal(0,0) = angle;"
