"s[0] = InputSignal(0,0);\n"
"s[1] = InputSignal(0,1);\n"
"s[2] = InputSignal(0,2);\n"
"\n"
"float vdc = InputSignal(0,3);\n"
"\n"
"int cnt = 0;\n"
"\n"
"for(int i=0; i<3; i++)\n"
"{\n"
"\tif(s[i])\n"
"\t{\n"
"\t\tcnt++;\n"
"\t}\n"
"}\n"
"\t\n"
"if(cnt == 1)\n"
"{\n"
"\tfor(int i=0; i<3; i++)\n"
"\t{\n"
"\t\tV[i] = 2.0/3.0 * vdc * s[i];\n"
"\t\t\n"
"\t\tif(!V[i])\n"
"\t\t{\n"
"\t\t\tV[i] = -1.0/3.0 * vdc;\n"
"\t\t}\n"
"\t}\n"
"}\n"
"else if(cnt == 2)\n"
"{\n"
"\tfor(int i=0; i<3; i++)\n"
"\t{\n"
"\t\tV[i] = 1.0/3.0 * vdc * s[i];\n"
"\t\t\n"
"\t\tif(!V[i])\n"
"\t\t{\n"
"\t\t\tV[i] = -2.0/3.0 * vdc;\n"
"\t\t}\n"
"\t}\n"
"}\n"
"else\n"
"{\n"
"\tfor(int i=0; i<3; i++)\n"
"\t{\n"
"\t\tV[i] = 0;\n"
"\t}\n"
"}\n"
"\n"
"cnt = 0;\n"
"\t\n"
"OutputSignal(0, 0) = V[0];\n"
"OutputSignal(0, 1) = V[1];\n"
"OutputSignal(0, 2) = V[2];"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
