            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "float prv_time;\n"
"float ts;\n"
"float psi_a,psi_b;"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "\n"
"float dpsi_a = Input(0);\n"
"float dpsi_b = Input(1);\n"
"\n"
"float fhp = 1.0;\n"
"\n"
"ts = CurrentTime - prv_time;\n"
"prv_time = CurrentTime;\n"
"\n"
"float gm = 2*3.14159*fhp*ts;\n"
"\n"
"psi_a = dpsi_a * ts + (1.0-gm) * psi_a;\n"
"psi_b = dpsi_b * ts + (1.0-gm) * psi_b;\n"
"\n"
"Output(0) = psi_a;\n"
"Output(1) = psi_b;"
            Show          off
          }
