Plecs {
  Name          "dtc_induction_v2"
  Version       "4.9"
  CircuitModel  "ContStateSpace"
  StartTime     "0.0"
  TimeSpan      "2"
  Timeout       ""
  Solver        "auto"
  MaxStep       "1e-4"
  InitStep      "-1"
  FixedStep     "5e-7"
  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-3"
  AbsTol        "-1"
  TurnOnThreshold "0"
  NonIdealSwitchResistance "1"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "3"
  NegativeSwitchLossMsg "3"
  DivisionByZeroMsg "3"
  DatatypeOverflowMsg "3"
  DatatypeInheritanceConflictMsg "2"
  ContSampleTimeConflictMsg "2"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "3"
  AssertionAction "1"
  FixedPointDatatypeOverride "1"
  InitializationCommands "% Control matrix\nZ0 = [0 0 0];\nZ1 = [1 0 0];\nZ2 ="
" [1 1 0];\nZ3 = [0 1 0];\nZ4 = [0 1 1];\nZ5 = [0 0 1];\nZ6 = [1 0 1];\nZ7 = ["
"1 1 1];\n\nTab = [ Z0; Z3; Z7; Z2;\n        Z7; Z4; Z0; Z3;\n        Z0; Z5; "
"Z7; Z4;\n        Z7; Z6; Z0; Z5;\n        Z0; Z1; Z7; Z6;\n        Z7; Z2; Z0"
"; Z1;\n        Z0; Z0; Z0; Z0;\n        Z0; Z0; Z0; Z0; ];\n\nal = 2000\n\nal"
"2 = 0.5\n\nal3 = 100\n\nLsig = 0.0416\nRR = 2.106\nRs = 4.3\npsi_nom = 0.9072"
"\nLls = (Lsig/2);%/(2*pi*60);\nLlr = (Lsig/2);\nLm = 0.3365;%/(2*pi*60);\n\nJ"
" = 0.01\nnp = 2\n\nsample_time = 5e-6\nsw_freq = 10e3\ncontrol_sample_time = "
"sample_time\n\nVdc = 400\n\nV_base = 230*sqrt(3);\nmax_rpm = 1500;\n\ndelta_T"
" = 0.1;\ndelta_Psi = 0.01;\n\nPsi_ref = psi_nom;\n\nKp_trq = 1;\nKi_trq = 10;"
"\n\nimax = 10;\nmax_trq = 15;\n\nt_rise_s = 200e-3;\nb = 0;\n\nas = log(9)/t_"
"rise_s;\nKps = as*J/np;\nKis = as^2*J/np;\nba = (as*J-b)/np;\n\nt_rise_w_sens"
"e = 20e-3;\naw = log(9)/t_rise_w_sense;\n\nspeed_sample_time = control_sample"
"_time*10;\n\nfb_opamp = 3e6;\nfb_sensor = 400e3;\n\na_opamp = log(9) * fb_opa"
"mp;\n\na_sensor = log(9) * fb_sensor;\n\nfc_hp = 0;\nwc_hp = 2*pi*fc_hp;"
