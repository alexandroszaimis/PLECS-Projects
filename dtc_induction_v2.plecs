            Variable      "Declarations"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "#include <math.h>"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "float trq_ref = InputSignal(0,0);\n"
"float psi = InputSignal(0,1);\n"
"\n"
"float imax = 5.0;\n"
"float imin = -imax;\n"
"float np = 2;\n"
"float psi_min = 0.01;\n"
"\n"
"if(psi == 0)\n"
"{\n"
"\tpsi = psi_min;\n"
"}\n"
"\n"
"float tmax = 3.0/2.0 * np*psi*imax;\n"
"\n"
"float tmin = 3.0/2.0 * np*psi*imin;\n"
"\n"
"float trq_ref_out = trq_ref;\n"
"\n"
"if(trq_ref > tmax)\n"
"{\n"
"\ttrq_ref_out = tmax;\n"
"}\n"
"if(trq_ref < tmin)\n"
"{\n"
"\ttrq_ref_out = tmin;\n"
"}\n"
"OutputSignal(0, 0) = trq_ref_out;\n"
"OutputSignal(0, 1) = tmax;\n"
"OutputSignal(0, 2) = tmin;"
            Show          off
          }
          Parameter {
