          Parameter {
            Variable      "Parameters"
            Value         "Lm, Lsig"
            Show          off
          }
          Parameter {
            Variable      "LangStandard"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "GnuExtensions"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "HighlightLevel"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "#include <math.h>\n"
"\n"
"float prv_time;\n"
"\n"
"float psi_a,psi_b;\n"
"\n"
"double Ts = 5e-6;\n"
"\n"
"double pi = 3.14159265358979323846;\n"
"\n"
"float fhp = 0.1;\n"
"\n"
"double wc;\n"
"double K;\n"
"\n"
"double norm;\n"
"\n"
"double b0;\n"
"double b1;\n"
"double b2;\n"
"double a1;\n"
"double a2;\n"
"\n"
"double dpsi_a_2;\n"
"double dpsi_a_1;\n"
"double psi_a_2;\n"
"double psi_a_1;\n"
"\n"
"double dpsi_b_2;\n"
"double dpsi_b_1;\n"
"double psi_b_2;\n"
"double psi_b_1;\n"
"double psi_a_hp, psi_b_hp;\n"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "\n"
"\n"
"\n"
"\n"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "\n"
"float u_a = Input(0);\n"
"float u_b = Input(1);\n"
"\n"
"Ts = CurrentTime - prv_time;\n"
"prv_time = CurrentTime;\n"
"\n"
"\tpsi_a += u_a * Ts;\n"
"\tpsi_b += u_b * Ts;\n"
"\n"
"\twc = 2.0 * pi * fhp;\n"
"\tK = tan(wc * Ts / 2.0);\n"
"\n"
"\tnorm = 1.0 / (1.0 + sqrt(2.0)*K + K*K);\n"
"\n"
"\tb0 =  1.0 * norm;\n"
"\tb1 = -2.0 * norm;\n"
"\tb2 =  1.0 * norm;\n"
"\ta1 =  2.0*(K*K - 1.0) * norm;\n"
"\ta2 =  (1.0 - sqrt(2.0)*K + K*K) * norm;\n"
"\t// Inputs: x[n], x[n-1], x[n-2]\n"
"\t// Outputs: y[n], y[n-1], y[n-2]\n"
"\tpsi_a_hp = b0*psi_a + b1*dpsi_a_1 + b2*dpsi_a_2\n"
"\t           - a1*psi_a_1 - a2*psi_a_2;\n"
"\n"
"\t// shift old samples\n"
"\tdpsi_a_2 = dpsi_a_1;\n"
"\tdpsi_a_1 = psi_a;\n"
"\tpsi_a_2 = psi_a_1;\n"
"\tpsi_a_1 = psi_a_hp;\n"
"\n"
"\tpsi_b_hp = b0*psi_b + b1*dpsi_b_1 + b2*dpsi_b_2\n"
"\t           - a1*psi_b_1 - a2*psi_b_2;\n"
"\n"
"\t// shift old samples\n"
"\tdpsi_b_2 = dpsi_b_1;\n"
"\tdpsi_b_1 = psi_b;\n"
"\tpsi_b_2 = psi_b_1;\n"
"\tpsi_b_1 = psi_b_hp;\n"
"\n"
"Output(0) = psi_a_hp;\n"
"Output(1) = psi_b_hp;\n"
"Output(2) = psi_a;\n"
"Output(3) = psi_b;"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "StoreCustomStateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "RestoreCustomStateFcn"
            Value         ""
            Show          off
          }
        }
