          Parameter {
            Variable      "Declarations"
            Value         "float psi_ramp;\n"
"float pr_time;"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "#include <math.h>\n"
"\n"
"psi_ramp = 0;\n"
"pr_time = 0;"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "float psi = InputSignal(0,0);\n"
"\n"
"float ts = CurrentTime - pr_time;\n"
"pr_time = CurrentTime;\n"
"\n"
"float Lm = 0.33;\n"
"float Rs = 4.3;\n"
"\n"
"\n"
"float ramp_time = Lm/Rs;\n"
"\n"
"if(psi_ramp < psi)\n"
"{\n"
"\tpsi_ramp += psi*ts/ramp_time;\n"
"}\n"
"if(psi_ramp > psi)\n"
"{\n"
"\tpsi_ramp -= psi*ts/ramp_time;\n"
"}\n"
"\n"
"OutputSignal(0, 0) = psi_ramp;"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
