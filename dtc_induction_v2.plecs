        Component {
          Type          CScript
          Name          "integrate"
          Show          on
          Position      [1020, 730]
          Direction     up
          Flipped       off
          LabelPosition south
          Parameter {
            Variable      "DialogGeometry"
            Value         "[739 217 1281 987]"
            Show          off
          }
          Parameter {
            Variable      "NumInputs"
            Value         "6"
            Show          off
          }
          Parameter {
            Variable      "NumOutputs"
            Value         "4"
            Show          off
          }
          Parameter {
            Variable      "NumContStates"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "NumDiscStates"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "NumZCSignals"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "DirectFeedthrough"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "Ts"
            Value         "sample_time"
            Show          off
          }
          Parameter {
            Variable      "TerminalBasedSampleTimes"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "Parameters"
            Value         "Lm, Lsig"
            Show          off
          }
          Parameter {
            Variable      "LangStandard"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "GnuExtensions"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "HighlightLevel"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "float prv_time;\n"
"\n"
"float psi_a,psi_b;\n"
"\n"
"double Ts = 5e-6;\n"
"\n"
"double fc1 = 0;\n"
"double fc2 = 500;\n"
"\n"
"double pi = 3.14159265358979323846;\n"
"\n"
"double wc1,wc2;\n"
"\n"
"// ================= Complementary Flux Estimator (no structs) =============="
"===\n"
"// Voltage path: leaky integrator H(s)=1/(s+wc) via Tustin\n"
"// Current path:  first-order LP with same wc via Tustin\n"
"// Sum gives flat response; voltage path handles mid/high f drift-free,\n"
"// current path supplies near-DC content.\n"
"\n"
"// -------- Coefficients (set by comp_init) --------\n"
"static double a1_li, b0_li, b1_li;   // leaky integrator\n"
"static double a1_lp, b0_lp, b1_lp;   // low-pass\n"
"\n"
"// -------- States (persist between calls) --------\n"
"// Voltage path states (per axis): previous input u[k-1], previous output psi"
"_v[k-1]\n"
"static double u_a1 = 0.0f, u_b1 = 0.0f;\n"
"static double psi_va1 = 0.0f, psi_vb1 = 0.0f;\n"
"\n"
"// Current path states (per axis): previous input x[k-1], previous output psi"
"_c[k-1]\n"
"static double x_a1 = 0.0f, x_b1 = 0.0f;\n"
"static double psi_ca1 = 0.0f, psi_cb1 = 0.0f;\n"
"\n"
"double psi_v_a;\n"
"double psi_v_b; \n"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "\n"
"wc1 = 2*pi*fc1;\n"
"wc2 = 2*pi*fc2;\n"
"\n"
"//reset\n"
"u_a1 = u_b1 = 0.0f;\n"
"psi_va1 = psi_vb1 = 0.0f;\n"
"x_a1 = x_b1 = 0.0f;\n"
"psi_ca1 = psi_cb1 = 0.0f;\n"
"\n"
"\n"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "\n"
"float u_a = Input(0);\n"
"float u_b = Input(1);\n"
"float i_a = Input(2);\n"
"float i_b = Input(3);\n"
"float Lls = Input(4);\n"
"float Lm = Input(5);\n"
"\n"
"float Ls = Lls + Lm;\n"
"\n"
"Ts = CurrentTime - prv_time;\n"
"prv_time = CurrentTime;\n"
"\n"
"    // Tustin mapping\n"
"    // For H_li(s)=1/(s+wc): y[k] = a1*y[k-1] + b0*x[k] + b1*x[k-1]\n"
"    // a1 = (1 - wc*Ts/2)/(1 + wc*Ts/2)\n"
"    // b0 = (Ts/2)/(1 + wc*Ts/2)\n"
"    // b1 = b0\n"
"    double k1 = 1.0f + 0.5f*wc1*Ts;\n"
"    double m1 = 1.0f - 0.5f*wc1*Ts;\n"
"\n"
"    a1_li = m1 / k1;\n"
"    b0_li = (0.5f*Ts) / k1;\n"
"    b1_li = b0_li;\n"
"\n"
"    double k2 = 1.0f + 0.5f*wc2*Ts;\n"
"    double m2 = 1.0f - 0.5f*wc2*Ts;\n"
"    // For 1st-order LP with same wc:\n"
"    // y[k] = a1*y[k-1] + b0*x[k] + b1*x[k-1]\n"
"    // a1 = (1 - wc*Ts/2)/(1 + wc*Ts/2)\n"
"    // b0 = (wc*Ts/2)/(1 + wc*Ts/2)\n"
"    // b1 = b0\n"
"    a1_lp = m2 / k2;\n"
"    b0_lp = (0.5f*wc2*Ts) / k2;\n"
"    b1_lp = b0_lp;\n"
"\n"
"float x_a = Ls * i_a;         // current model input (per axis)\n"
"float x_b = Ls * i_b;\n"
"\n"
"    // --- Voltage path (leaky integrator of u) ---\n"
"float psi_v_a = a1_li * psi_va1 + b0_li * u_a + b1_li * u_a1;\n"
"float psi_v_b = a1_li * psi_vb1 + b0_li * u_b + b1_li * u_b1;\n"
"\n"
"    // Update voltage-path states\n"
"u_a1 = u_a;  \n"
"u_b1 = u_b;\n"
"psi_va1 = psi_v_a;  \n"
"psi_vb1 = psi_v_b;\n"
"\n"
"    // --- Current path (LP of Ls*i) ---\n"
"float psi_c_a = a1_lp * psi_ca1 + b0_lp * x_a + b1_lp * x_a1;\n"
"float psi_c_b = a1_lp * psi_cb1 + b0_lp * x_b + b1_lp * x_b1;\n"
"\n"
"    // Update current-path states\n"
"x_a1 = x_a;  \n"
"x_b1 = x_b;\n"
"psi_ca1 = psi_c_a;  \n"
"psi_cb1 = psi_c_b;\n"
"\n"
"    // --- Complementary sum ---\n"
"psi_a = psi_v_a + psi_c_a;\n"
"psi_b = psi_v_b + psi_c_b;\n"
"\n"
"Output(0) = psi_v_a;\n"
"Output(1) = psi_c_a;\n"
"Output(2) = psi_v_b;\n"
"Output(3) = psi_c_b;"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "StoreCustomStateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "RestoreCustomStateFcn"
            Value         ""
            Show          off
          }
        }
