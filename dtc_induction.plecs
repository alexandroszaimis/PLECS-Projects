          Name          "sw frq limit"
          Show          on
          Position      [335, 910]
          Direction     up
          Flipped       off
          LabelPosition south
          Parameter {
            Variable      "DialogGeometry"
            Value         "[879 479 1638 1132]"
            Show          off
          }
          Parameter {
