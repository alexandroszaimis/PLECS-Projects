"\n"
"double percentage;"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "dtrq = InputSignal(0,0);\n"
"\n"
"wm = InputSignal(0,1);\n"
"\n"
"trq_ref = InputSignal(0,2);\n"
"\n"
"trq = InputSignal(0,3);\n"
"\n"
"percentage = InputSignal(0,4);\n"
"\n"
"hyst = 0.2;//((trq_ref+trq)/2.0)*(percentage/100.0);\n"
"\n"
"if(dtrq > hyst){\n"
"\tdt = 1;\n"
"}\n"
"else if(dtrq < -hyst){\n"
"\tdt = 0;\n"
"}\n"
"else{\n"
"\tdt = dt_prv;\n"
"}\n"
"\n"
"if(wm < 0){\n"
"\tdt -= 1;\n"
"}\n"
"\n"
"dt_prv = dt;\n"
"\n"
"OutputSignal(0,0) = dt;"
            Show          off
          }
