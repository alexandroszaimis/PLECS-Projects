          Parameter {
            Variable      "OutputFcn"
            Value         "float LM = Input(0);\n"
"float RR = Input(1);\n"
"float Id = Input(2);\n"
"float Iq = Input(3);\n"
"float psi_r_d = Input(4);\n"
"float psi_r_q = Input(5);\n"
"\n"
"float dpsi_r = 0;\n"
"\n"
"float ts = CurrentTime - tick;\n"
"tick = CurrentTime;\n"
"\n"
