            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "int in[3];\n"
"int in_prv[3];\n"
"\n"
"float prv_time[3];\n"
"float tsw_actual[3];\n"
"float fsw_actual[4];\n"
"\n"
"int cnt[3];"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "float curr_time = CurrentTime;\n"
"\n"
"for(int i=0; i<3; i++){\n"
"\n"
"\tin[i] = Input(i);\n"
"\tif (in[i] != in_prv[i]) {  // a real switch occurred\n"
"    \ttsw_actual[i] += curr_time - prv_time[i];\n"
"    \tprv_time[i]   = curr_time;\n"
"    \tcnt[i]++;\n"
"\t}\n"
"\t\n"
"\tif(cnt[i] == 2)\n"
"\t{\n"
"\t\tfsw_actual[i] = cnt[i]/2 * 1.0 / tsw_actual[i];\n"
"\t\ttsw_actual[i] = 0;\n"
"\t\tcnt[i] = 0;\n"
"\t}\n"
"\n"
"\tOutput(i) = fsw_actual[i];\n"
"\tOutput(i+3) = tsw_actual[i];\n"
"\tOutput(i+6) = in[i]; \n"
"\tOutput(i+9) = in_prv[i]; \n"
"\tin_prv[i] = in[i];\n"
"}\n"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
