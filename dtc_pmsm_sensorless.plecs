              Parameter {
                Variable      "Declarations"
                Value         "double angle, prv_input;\n"
"\n"
"int rotation = 0;\n"
"\n"
"double pi = 3.1415926535897932384626433832795;"
                Show          off
              }
              Parameter {
                Variable      "StartFcn"
                Value         ""
                Show          off
              }
              Parameter {
                Variable      "OutputFcn"
                Value         "if(Input(0) < (prv_input - pi))\n"
"{\n"
"\trotation++;\n"
"}\n"
"if(Input(0) > (prv_input + pi))\n"
"{\n"
"\trotation--;\n"
"}\n"
"\n"
"prv_input = Input(0);\n"
"\n"
"angle = (double)rotation * 2*pi + Input(0);\n"
"\n"
"if(rotation > 1000)\n"
"{\n"
"rotation = 0;\n"
"}\n"
"if(rotation < -1000)\n"
"{\n"
"rotation = 0;\n"
"}\n"
"Output(0) = angle;\n"
                Show          off
              }
