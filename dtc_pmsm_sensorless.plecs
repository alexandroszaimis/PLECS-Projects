"{\n"
"\tif((Input(0) < (1000*2*pi - 0.1)) && (Input(0) > -1000*2*pi + 0.1)){\n"
"   \t\n"
"   \t out = (Input(0) - lastInput)/(CurrentTime - lastTime);\n"
"   \t \n"
"   \t Output(0) = out;\n"
"   }\n"
"   else\n"
"   {\n"
"   \tOutput(0) = Input(1);\n"
"   }\n"
"}"
