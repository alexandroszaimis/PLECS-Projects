                }
                Parameter {
                  Variable      "Ts"
                  Value         "0"
                  Show          off
                }
                Parameter {
                  Variable      "TerminalBasedSampleTimes"
                  Value         "1"
                  Show          off
                }
                Parameter {
                  Variable      "Parameters"
                  Value         "R, Lls, Ld, Lq, phi, p, thm0*p, is0"
                  Show          off
                }
                Parameter {
                  Variable      "LangStandard"
                  Value         "1"
                  Show          off
                }
                Parameter {
                  Variable      "GnuExtensions"
                  Value         "1"
                  Show          off
                }
                Parameter {
                  Variable      "RuntimeCheck"
                  Value         "1"
                  Show          off
                }
                Parameter {
                  Variable      "HighlightLevel"
                  Value         "0"
                  Show          off
                }
                Parameter {
                  Variable      "Declarations"
                  Value         "#include\t<math.h>\n"
"\n"
"#define\tv_a\t\t\tInputSignal(0,0)\n"
"#define\tv_b\t\t\tInputSignal(0,1)\n"
"#define\tv_c\t\t\tInputSignal(0,2)\n"
"#define\tw_r\t\t\tInputSignal(0,3)\n"
"#define\tcos_th\t\tInputSignal(0,4)\n"
"#define\tsin_th\t\tInputSignal(0,5)\n"
"\n"
"#define\ti_d\t\t\tContState(0)\n"
"#define\ti_q\t\t\tContState(1)\n"
"#define\ti_0\t\t\tContState(2)\n"
"#define\tpi_d\t\t\tContDeriv(0)\n"
"#define\tpi_q\t\t\tContDeriv(1)\n"
"#define\tpi_0\t\t\tContDeriv(2)\n"
"\n"
"#define\tyi_d\t\t\tOutputSignal(0,0)\n"
"#define\tyi_q\t\t\tOutputSignal(0,1)\n"
"#define\tyi_0\t\t\tOutputSignal(0,2)\n"
"#define\tylambda_d\t\tOutputSignal(0,3)\n"
"#define\tylambda_q\t\tOutputSignal(0,4)\n"
"#define\tylambda_0\t\tOutputSignal(0,5)\n"
"#define\tT_e\t\t\tOutputSignal(0,6)\n"
"\n"
"#define\tpi\t\t\t3.14159265358979323846\n"
"\n"
"static double r, L_d, L_q, L_ls, p, L_d_inv, L_q_inv, L_0_inv, lambda_d, lamb"
"da_q, lambda_m;\n"
                  Show          off
                }
                Parameter {
                  Variable      "StartFcn"
                  Value         "double theta_r0, i_a0, i_b0, i_c0, cos_0, cos"
"_n, cos_p, sin_0, sin_n, sin_p;\n"
"\n"
"int ParIdx = 0;\n"
"if (NumParameters != 8)\n"
"{\n"
"   SetErrorMessage(\"Number of parameters does not match.\");\n"
"   return;\n"
"}\n"
"\n"
"r\t\t\t\t= ParamRealData(ParIdx++, 0);\n"
"L_ls\t\t\t= ParamRealData(ParIdx++, 0);\n"
"L_d\t\t\t= ParamRealData(ParIdx++, 0);\n"
"L_q\t\t\t= ParamRealData(ParIdx++, 0);\n"
"lambda_m\t\t= ParamRealData(ParIdx++, 0);\n"
"p\t\t\t\t= ParamRealData(ParIdx++, 0);\n"
"theta_r0\t\t= ParamRealData(ParIdx++, 0);\n"
"i_a0\t\t\t= ParamRealData(ParIdx, 0);\n"
"i_b0\t\t\t= ParamRealData(ParIdx, 1);\n"
"i_c0\t\t\t= ParamRealData(ParIdx, 2);\n"
"\n"
"cos_0 = cos(theta_r0);\n"
"sin_0 = sin(theta_r0);\n"
"cos_n = -cos_0*0.5 + sin_0*sqrt(3.)/2.;\n"
"cos_p = -cos_0*0.5 - sin_0*sqrt(3.)/2.;\n"
"sin_n = -sin_0*0.5 - cos_0*sqrt(3.)/2.;\n"
"sin_p = -sin_0*0.5 + cos_0*sqrt(3.)/2.;\n"
"\n"
"i_d =  2./3.*(i_a0*cos_0 + i_b0*cos_n + i_c0*cos_p);\n"
"i_q = -2./3.*(i_a0*sin_0 + i_b0*sin_n + i_c0*sin_p);\n"
"i_0 =  1./3.*(i_a0+i_b0+i_c0);\n"
"\n"
"L_d_inv=1./L_d;\n"
"L_q_inv=1./L_q;\n"
"L_0_inv=1./L_ls;"
                  Show          off
                }
                Parameter {
                  Variable      "OutputFcn"
                  Value         "yi_d = i_d;\n"
"yi_q = i_q;\n"
"yi_0 = i_0;\n"
"\n"
"lambda_d = (L_d*i_d + lambda_m);\n"
"lambda_q = (L_q*i_q );\n"
"\n"
"T_e = 3./2.*p*(i_q*lambda_d-i_d*lambda_q);\n"
"\n"
"ylambda_d = lambda_d;\n"
"ylambda_q = lambda_q;\n"
"ylambda_0 = L_ls*i_0;\n"
                  Show          off
                }
                Parameter {
                  Variable      "UpdateFcn"
                  Value         ""
                  Show          off
                }
                Parameter {
                  Variable      "DerivativeFcn"
                  Value         "double v_d =  2./3.*v_a*cos_th - 1./3.*v_b*(c"
"os_th-sqrt(3.)*sin_th) - 1./3.*v_c*(cos_th+sqrt(3.)*sin_th);\n"
"double v_q = -2./3.*v_a*sin_th + 1./3.*v_b*(sin_th+sqrt(3.)*cos_th) + 1./3.*v"
"_c*(sin_th-sqrt(3.)*cos_th);\n"
"double v_0 =  1./3.*(v_a+v_b+v_c);\n"
"\n"
"pi_d = L_d_inv * ( \n"
"\t- r * i_d  \n"
"\t+ w_r * lambda_q\n"
"\t+ v_d\n"
"\t) ;\n"
"\n"
"pi_q = L_q_inv * ( \n"
"\t- r * i_q  \n"
"\t- w_r * lambda_d \n"
"\t+ v_q \n"
"\t);\n"
"\n"
"pi_0 = L_0_inv * (\n"
"\t- r * i_0 \n"
"\t+ v_0 \n"
"\t);\n"
                  Show          off
                }
                Parameter {
                  Variable      "TerminateFcn"
                  Value         ""
                  Show          off
                }
                Parameter {
                  Variable      "StoreCustomStateFcn"
                  Value         ""
                  Show          off
                }
                Parameter {
                  Variable      "RestoreCustomStateFcn"
                  Value         ""
                  Show          off
                }
              }
