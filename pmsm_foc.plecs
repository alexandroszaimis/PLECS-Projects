    Component {
      Type          CScript
      Name          "C-Script"
      Show          on
      Position      [765, 175]
      Direction     up
      Flipped       off
      LabelPosition south
      Parameter {
        Variable      "DialogGeometry"
        Value         "[581 231 694 699]"
        Show          off
      }
