Plecs {
  Name          "pmsm_foc"
  Version       "5.0"
  CircuitModel  "ContStateSpace"
  StartTime     "0.0"
  TimeSpan      "1"
  Timeout       ""
  Solver        "auto"
  MaxStep       "1e-3"
  InitStep      "-1"
  FixedStep     "1e-7"
  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-3"
  AbsTol        "-1"
  TurnOnThreshold "0"
  NonIdealSwitchResistance "1"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "3"
  NegativeSwitchLossMsg "3"
  DivisionByZeroMsg "3"
  DatatypeOverflowMsg "3"
  DatatypeInheritanceConflictMsg "2"
  ContSampleTimeConflictMsg "2"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "3"
  AssertionAction "1"
  FixedPointDatatypeOverride "1"
  InitializationCommands "%if connection is delta gain should be sqrt(3), if s"
"tar 1\ndelta_gain = sqrt(3);\n\nVdc = 600;\n\nv_base = 600;\n\nI_max = 50;\n"
"\nJ = 2.74e-4\nnp = 5\n\nno_load_rpm = 18617;\n\nno_load_rpm_act = no_load_rp"
"m*Vdc/v_base;\n\nw_base_nom = no_load_rpm_act * 2*pi/60;\n\nnom_rpm = 12000;"
"\n\nnom_rpm_act = nom_rpm*Vdc/v_base;\n\nw_base = np * nom_rpm_act * 2*pi/60;"
"\n\nfsw = 32000;\n\npsi_pm_actual = 0.047;\nRs_actual = 0.2;\nLd_actual = 700"
"e-6;\nLq_actual = 820e-6;\n\nJ_ctrl = 2*J;\npsi_pm = psi_pm_actual;\nRs = Rs_"
"actual;\nLd = Ld_actual;\nLq = Lq_actual;\n\ntr = 1e-3;\nac = log(9)/tr\n\ntr"
"_fw = 10e-3;\nafw = log(9)/tr_fw\n\nRa_d = ac*Ld-Rs;\nRa_q = ac*Lq-Rs;;\nKp_d"
" = ac*Ld;\nKp_q = ac*Lq;\nKi_d = (ac^2)*Ld;\nKi_q = (ac^2)*Lq;\n\nsample_time"
" = 1/(2*fsw);\n\nMA1 = 2/sqrt(3)\n\ntr_s = 20e-3;\nK = 1;\nas=log(9)/tr_s;   "
" % one decade slower than the current control loop\n\nb = 0.0005\nKps = 2*K^2"
" * as * J_ctrl/(3*np^2);\nKis = 2*K^2 * as^2 * J_ctrl/(3*np^2);\nba = 2 * K^2"
" * (as * J_ctrl - 0)/(3*np^2);\n\na_sensor = 2*pi*(170e3*400e3/(170e3+400e3))"
";\n\nf_pll = 100;\na_pll = 2*pi*f_pll;\nzeta = 1;\nKp_pll = 2*zeta*a_pll;\nKi"
"_pll = a_pll^2;\n\nalpha = 0.03;\nbeta = 0.0009;\n\nLam = 0\nang_init = 0\n\n"
"K_chc = 1000\n\na_l = 1000;\naz = 1-e^(-a_l*sample_time)"
  InitialState  "1"
  SystemState   ""
  JacobianComputation "2"
  TaskingMode   "1"
