          Name          "psi_r est1"
          Show          on
          Position      [405, 815]
          Direction     up
          Flipped       off
          LabelPosition south
          CommentOut    DisabledOpenCircuit
          Parameter {
            Variable      "DialogGeometry"
            Value         "[542 304 1090 656]"
            Show          off
          }
          Parameter {
            Variable      "NumInputs"
            Value         "7"
            Show          off
          }
