Plecs {
  Name          "induction_foc"
  Version       "4.9"
  CircuitModel  "ContStateSpace"
  StartTime     "0.0"
  TimeSpan      "2"
  Timeout       ""
  Solver        "auto"
  MaxStep       "1e-3"
  InitStep      "-1"
  FixedStep     "1e-3"
  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-3"
  AbsTol        "-1"
  TurnOnThreshold "0"
  NonIdealSwitchResistance "1"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "3"
  NegativeSwitchLossMsg "3"
  DivisionByZeroMsg "3"
  DatatypeOverflowMsg "3"
  DatatypeInheritanceConflictMsg "2"
  ContSampleTimeConflictMsg "2"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "3"
  AssertionAction "1"
  FixedPointDatatypeOverride "1"
  InitializationCommands "%if connection is delta gain should be sqrt(3), if s"
"tar 1\ndelta_gain = 1;\n\nVdc = 60;\n\nv_base = 400;\n\nJ = 0.01\nnp = 2\n\nw"
"_base_nom = 1500 * 2*pi/60;\n\nnom_rpm = 1500*Vdc/v_base;\nw_base = np * nom_"
"rpm * 2*pi/60;\n\nfsw = 20000;\n\npsi_nom = 0.9072;\n\nLsig_actual = 0.0416;"
"\nRR_actual = 2.106;\nRs_actual = 4.6;\nLls_actual = (Lsig_actual/2);\nLlr_ac"
"tual = (Lsig_actual/2);\nLm_actual = 0.3365;\n\nLsig = Lsig_actual\nRR = RR_a"
"ctual\nRs = 4.6\nLls = Lls_actual\nLlr = Llr_actual\nLm = Lm_actual\n\nId_nom"
" = 2.7;\n\ntr = 2e-3;\n\nac=log(9)/tr;\nRa = ac*Lsig-Rs-RR;\nKp=ac*Lsig;\nKi="
"(ac^2)*Lsig;\n\nlamda_svcm = 1.5;\ntr_svcm = 50e-3;\nal_svcm = log(9)/tr_svcm"
";\n\nsample_time = 50e-6;\n\nMA1 = 2/sqrt(3)\n\nmcm_t_rise = 10e-3;\n\nlamda_"
"mcm = 1.5;\nwdelta = 0.1*w_base;\nal_mcm = log(9)/mcm_t_rise;\n\nlamda_scvm ="
" 1.5;\ntr_s = 0.2;\nK = 1;\nas=log(9)/tr_s;    % one decade slower than the c"
"urrent control loop\n%Kps=as*J/psi_nom;\nKps = 2*K^2 * as * J/(3*np^2 * psi_n"
"om);\n\n%Kis=(as^2)*J/psi_nom;\nKis = 2*K^2 * as^2 * J/(3*np^2 * psi_nom);\n"
"\n%ba=(as*J)/psi_nom; \nba = 2 * K^2 * (as * J)/(3*np^2 * psi_nom);"
  InitialState  "1"
  SystemState   ""
  TaskingMode   "1"
  TaskConfigurations ""
  CodeGenParameterInlining "2"
  CodeGenFloatingPointFormat "2"
  CodeGenAbsTimeUsageMsg "3"
  CodeGenBaseName ""
  CodeGenOutputDir ""
  CodeGenExtraOpts ""
  CodeGenTarget "Generic"
  CodeGenTargetSettings ""
  ExtendedMatrixPrecision "1"
