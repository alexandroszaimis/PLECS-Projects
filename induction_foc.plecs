      Type          CScript
      Name          "fsw monitor"
      Show          on
      Position      [1935, 1260]
      Direction     up
      Flipped       off
      LabelPosition south
      Parameter {
        Variable      "DialogGeometry"
        Value         "[5229 673 457 319]"
        Show          off
      }
      Parameter {
