            Variable      "StartFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "float LM = Input(0);\n"
"float RR = Input(1);\n"
"float Id = Input(2);\n"
"float Iq = Input(3);\n"
"float psi_r_d = Input(4);\n"
"float psi_r_q = Input(5);\n"
"\n"
"float dpsi_r = 0;\n"
"\n"
"float ts = CurrentTime - tick;\n"
"tick = CurrentTime;\n"
"\n"
"dpsi_r = -RR/LM * psi_r_d + RR * Id;\n"
"\n"
"psi_r = psi_r_d + ts*dpsi_r;\n"
"\n"
"Output(0) = psi_r;\n"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "StoreCustomStateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "RestoreCustomStateFcn"
            Value         ""
            Show          off
          }
