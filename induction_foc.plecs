Plecs {
  Name          "induction_foc"
  Version       "4.9"
  CircuitModel  "ContStateSpace"
  StartTime     "0.0"
  TimeSpan      "2"
  Timeout       ""
  Solver        "radau"
  MaxStep       "1e-4"
  InitStep      "-1"
  FixedStep     "1e-3"
  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-3"
  AbsTol        "-1"
  TurnOnThreshold "0"
  NonIdealSwitchResistance "1"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "3"
  NegativeSwitchLossMsg "3"
  DivisionByZeroMsg "3"
  DatatypeOverflowMsg "3"
  DatatypeInheritanceConflictMsg "2"
  ContSampleTimeConflictMsg "2"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "3"
  AssertionAction "1"
  FixedPointDatatypeOverride "1"
  InitializationCommands "%if connection is delta gain should be sqrt(3), if s"
"tar 1\ndelta_gain = 1%sqrt(3);\n\nVdc = 400;\n\nv_base = 400;\n\nI_max = 5;\n"
"\nJ = 0.01\nnp = 2\n\nw_base_nom = 1500 * 2*pi/60;\n\nnom_rpm = 1500*Vdc/v_ba"
"se;\nw_base = np * nom_rpm * 2*pi/60;\n\nfsw = 1000;\n\npsi_nom = 0.9072;\n\n"
"Lsig_actual = 0.0416;\nRR_actual = 2.106;\nRs_actual = 4.6;\nLls_actual = (Ls"
"ig_actual/2);\nLlr_actual = (Lsig_actual/2);\nLm_actual = 0.3365;\n\nLsig = L"
"sig_actual\nRR = RR_actual\nRs = Rs_actual\nLls = Lls_actual\nLlr = Llr_actua"
"l\nLm = Lm_actual\n\nLd = Lsig;\nLq = Lsig;\n\nksi = (Lsig+Lm)/Lsig;\nId_nom "
"= psi_nom/Lm;\n\ntr = 10e-3;\n\nac=log(9)/tr;\nRa = ac*Lsig-Rs-RR;\nKp=ac*Lsi"
"g;\nKi=(ac^2)*Lsig;\n\nRa_d = Ra;\nRa_q = Ra;\nKp_d = Kp;\nKp_q = Kp;\nKi_d ="
" Ki;\nKi_q = Ki;\n\nlamda_svcm = 1.5;\ntr_svcm = 60e-3;\nal_svcm = log(9)/tr_"
"svcm;\n\nsample_time = 1/(2*fsw);\n\nMA1 = 2/sqrt(3)\n\nmcm_t_rise = tr*10;\n"
"\nlamda_mcm = 1.5;\nwdelta = 0.1*w_base;\nal_mcm = log(9)/mcm_t_rise;\n\nlamd"
"a_scvm = 1.5;\ntr_s = 40*tr;\nK = 1;\nas=log(9)/tr_s;    % one decade slower "
"than the current control loop\n%Kps=as*J/psi_nom;\nKps = 2*K^2 * as * J/(3*np"
"^2);\n\n%Kis=(as^2)*J/psi_nom;\nKis = 2*K^2 * as^2 * J/(3*np^2);\n\n%ba=(as*J"
")/psi_nom; \nba = 2 * K^2 * (as * J)/(3*np^2);\n\na_sensor = 2*pi*(170e3*400e"
"3/(170e3+400e3));\n\n%DFOC%\nt_rise_w_sense = 10e-3;\naw = log(9)/t_rise_w_se"
"nse;\n\nfc_hp = 0.01;\nwc_hp = 2*pi*fc_hp;\n\nLam = 0.5;\n\nmax_trq = 3;\n\nm"
"ax_dwdt = max_trq/J;\n\nfc = 2;"
  InitialState  "1"
  SystemState   ""
  TaskingMode   "1"
  TaskConfigurations ""
  CodeGenParameterInlining "2"
