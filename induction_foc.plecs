        Variable      "Declarations"
        Value         "float time_prv = 0;\n"
"\n"
"float outp = 0;"
        Show          off
      }
      Parameter {
        Variable      "StartFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "OutputFcn"
        Value         "float inp = Input(0);\n"
"\n"
"float ramp_rise = Input(1);\n"
"\n"
"if(outp > 1200) ramp_rise = ramp_rise *5;\n"
"\n"
"float ts = CurrentTime - time_prv;\n"
"time_prv = CurrentTime;\n"
"\n"
"if(inp > outp)\n"
"{\n"
"\toutp += inp * ts/ramp_rise;\n"
"}\n"
"if(inp < outp)\n"
"{\n"
"\toutp -= inp * ts/ramp_rise;\n"
"}\n"
"\n"
"Output(0) = outp;"
        Show          off
      }
      Parameter {
        Variable      "UpdateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "DerivativeFcn"
        Value         ""
        Show          off
      }
      Parameter {
